{
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); model=$(echo \"$input\" | jq -r '.model.display_name'); total_input=$(echo \"$input\" | jq -r '.context_window.total_input_tokens'); total_output=$(echo \"$input\" | jq -r '.context_window.total_output_tokens'); total_tokens=$((total_input + total_output)); budget_pct=$((total_tokens * 100 / 200000)); printf '%s | Tokens: %d | Budget: %d%%' \"$model\" \"$total_tokens\" \"$budget_pct\""
  },
  "permissions": {
    "allow": [
      "Read(./**)",
      "Edit(./**)",
      "Bash(python manage.py *)",
      "Bash(pytest *)",
      "Bash(pytest)",
      "Bash(ruff check *)",
      "Bash(ruff format *)",
      "Bash(pip install *)",
      "Bash(pip freeze *)",
      "Bash(git status *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push origin *)",
      "Bash(git pull origin *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git merge *)",
      "Bash(git tag *)",
      "Bash(git stash *)",
      "Bash(git fetch *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(echo *)",
      "Bash(celery *)",
      "Bash(redis-cli *)",
      "WebFetch(domain:api.anthropic.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:pypi.org)"
    ],
    "deny": [
      "Read(~/**)",
      "Read(/etc/**)",
      "Read(/var/**)",
      "Edit(~/**)",
      "Edit(/etc/**)",
      "Edit(/var/**)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(docker *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(kill -9 *)",
      "Bash(pkill *)",
      "Bash(nc *)",
      "Bash(nmap *)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false,
    "excludedCommands": [
      "git"
    ],
    "network": {
      "allowLocalBinding": true
    }
  },
  "env": {
    "DJANGO_SETTINGS_MODULE": "config.settings.dev",
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "includeCoAuthoredBy": true
}
